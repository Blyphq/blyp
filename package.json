{
  "name": "@blyp/core",
  "version": "0.1.21",
  "description": "A high-performance, modular logger with Bun-first runtime detection and TypeScript support. Built on Pino and supports Elysia, Hono, Express, Fastify, NestJS, Next.js App Router, React Router, Astro, Nitro, Nuxt, TanStack Start, and SvelteKit.",
  "keywords": [
    "logger",
    "pino",
    "elysia",
    "standalone",
    "bun",
    "typescript",
    "logging"
  ],
  "author": "Mohammed Ibrahim",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Blyphq/blyp.git"
  },
  "bugs": {
    "url": "https://github.com/Blyphq/blyp/issues"
  },
  "homepage": "https://github.com/Blyphq/blyp#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./standalone": {
      "types": "./types/frameworks/standalone.d.ts",
      "import": "./exports/frameworks/standalone.mjs",
      "require": "./exports/frameworks/standalone.js"
    },
    "./elysia": {
      "types": "./types/frameworks/elysia.d.ts",
      "import": "./exports/frameworks/elysia.mjs",
      "require": "./exports/frameworks/elysia.js"
    },
    "./hono": {
      "types": "./types/frameworks/hono.d.ts",
      "import": "./exports/frameworks/hono.mjs",
      "require": "./exports/frameworks/hono.js"
    },
    "./express": {
      "types": "./types/frameworks/express.d.ts",
      "import": "./exports/frameworks/express.mjs",
      "require": "./exports/frameworks/express.js"
    },
    "./fastify": {
      "types": "./types/frameworks/fastify.d.ts",
      "import": "./exports/frameworks/fastify.mjs",
      "require": "./exports/frameworks/fastify.js"
    },
    "./nestjs": {
      "types": "./types/frameworks/nestjs.d.ts",
      "import": "./exports/frameworks/nestjs.mjs",
      "require": "./exports/frameworks/nestjs.js"
    },
    "./nextjs": {
      "types": "./types/frameworks/nextjs.d.ts",
      "import": "./exports/frameworks/nextjs.mjs",
      "require": "./exports/frameworks/nextjs.js"
    },
    "./react-router": {
      "types": "./types/frameworks/react-router.d.ts",
      "import": "./exports/frameworks/react-router.mjs",
      "require": "./exports/frameworks/react-router.js"
    },
    "./tanstack-start": {
      "types": "./types/frameworks/tanstack-start.d.ts",
      "import": "./exports/frameworks/tanstack-start.mjs",
      "require": "./exports/frameworks/tanstack-start.js"
    },
    "./sveltekit": {
      "types": "./types/frameworks/sveltekit.d.ts",
      "import": "./exports/frameworks/sveltekit.mjs",
      "require": "./exports/frameworks/sveltekit.js"
    },
    "./astro": {
      "types": "./types/frameworks/astro.d.ts",
      "import": "./exports/frameworks/astro.mjs",
      "require": "./exports/frameworks/astro.js"
    },
    "./nitro": {
      "types": "./types/frameworks/nitro.d.ts",
      "import": "./exports/frameworks/nitro.mjs",
      "require": "./exports/frameworks/nitro.js"
    },
    "./nuxt": {
      "types": "./types/frameworks/nuxt.d.ts",
      "import": "./exports/frameworks/nuxt.mjs",
      "require": "./exports/frameworks/nuxt.js"
    },
    "./client": {
      "types": "./types/client.d.ts",
      "import": "./exports/client.mjs",
      "require": "./exports/client.js"
    },
    "./expo": {
      "types": "./types/expo.d.ts",
      "import": "./exports/expo.mjs",
      "require": "./exports/expo.js"
    },
    "./database": {
      "types": "./types/database.d.ts",
      "import": "./exports/database.mjs",
      "require": "./exports/database.js"
    },
    "./betterstack": {
      "types": "./types/connectors/betterstack.d.ts",
      "import": "./exports/connectors/betterstack.mjs",
      "require": "./exports/connectors/betterstack.js"
    },
    "./databuddy": {
      "types": "./types/connectors/databuddy.d.ts",
      "import": "./exports/connectors/databuddy.mjs",
      "require": "./exports/connectors/databuddy.js"
