    "access": "public"
  },
  "scripts": {
    "test": "bun test tests/",
    "test:watch": "bun test tests/ --watch",
    "test:all": "bun test tests/",
    "benchmark": "bun run benchmarks/run.ts",
    "benchmark:json": "bun run benchmarks/run.ts --json-only",
    "benchmark:report": "bun run benchmarks/report.ts",
    "benchmark:update-docs": "bun run benchmarks/report.ts --update-docs",
    "build": "bun run build:js && bun run build:types",
    "build:js": "tsup",
    "build:types": "bun run tsc --project tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "type-check": "bun run tsc --noEmit",
    "dev": "bun run test:watch",
    "lint": "bun run type-check",
    "clean": "rm -rf dist .log"
  },
