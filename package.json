      ],
      "posthog": [
        "./types/connectors/posthog.d.ts"
      ],
      "otlp": [
        "./types/connectors/otlp.d.ts"
      ],
      "sentry": [
        "./types/connectors/sentry.d.ts"
      ],
      "elysia": [
        "./types/frameworks/elysia.d.ts"
      ],
      "hono": [
        "./types/frameworks/hono.d.ts"
      ],
      "express": [
        "./types/frameworks/express.d.ts"
      ],
      "fastify": [
        "./types/frameworks/fastify.d.ts"
      ],
      "nestjs": [
        "./types/frameworks/nestjs.d.ts"
      ],
      "nextjs": [
        "./types/frameworks/nextjs.d.ts"
      ],
      "react-router": [
        "./types/frameworks/react-router.d.ts"
      ],
      "tanstack-start": [
        "./types/frameworks/tanstack-start.d.ts"
      ],
      "sveltekit": [
        "./types/frameworks/sveltekit.d.ts"
      ],
      "astro": [
        "./types/frameworks/astro.d.ts"
      ],
      "nitro": [
        "./types/frameworks/nitro.d.ts"
      ],
      "nuxt": [
        "./types/frameworks/nuxt.d.ts"
      ],
      "standalone": [
        "./types/frameworks/standalone.d.ts"
      ],
      "workers": [
        "./types/workers.d.ts"
      ],
      "*": [
        "./types/index.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "exports",
    "types",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "bun test tests/",
    "test:watch": "bun test tests/ --watch",
    "test:all": "bun test tests/",
    "build": "bun run build:js && bun run build:types",
    "build:js": "tsup",
    "build:types": "bun run tsc --project tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "type-check": "bun run tsc --noEmit",
    "dev": "bun run test:watch",
    "lint": "bun run type-check",
    "clean": "rm -rf dist .log"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.8",
    "@nestjs/core": "^11.1.8",
    "@nestjs/platform-express": "^11.1.8",
