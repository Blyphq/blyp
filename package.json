    "./posthog": {
      "types": "./types/connectors/posthog.d.ts",
      "import": "./exports/connectors/posthog.mjs",
      "require": "./exports/connectors/posthog.js"
    },
    "./otlp": {
      "types": "./types/connectors/otlp.d.ts",
      "import": "./exports/connectors/otlp.mjs",
      "require": "./exports/connectors/otlp.js"
    },
    "./sentry": {
      "types": "./types/connectors/sentry.d.ts",
      "import": "./exports/connectors/sentry.mjs",
      "require": "./exports/connectors/sentry.js"
    },
    "./workers": {
      "types": "./types/workers.d.ts",
      "import": "./exports/workers.mjs",
      "require": "./exports/workers.js"
    }
  },
  "typesVersions": {
    "*": {
      "client": [
        "./types/client.d.ts"
      ],
      "expo": [
        "./types/expo.d.ts"
      ],
      "database": [
        "./types/database.d.ts"
      ],
      "betterstack": [
        "./types/connectors/betterstack.d.ts"
